{
    "name": "logingrupa/oc-metapixel-plugin",
    "type": "october-plugin",
    "description": "Meta Pixel + Conversions API for OctoberCMS",
    "license": "proprietary",
    "authors": [
        {
            "name": "Logingrupa",
            "email": "info@logingrupa.lv"
        }
    ],
    "require": {
        "php": "^8.3 || ^8.4",
        "october/system": "^4.0",
        "lovata/toolbox-plugin": "^2.2"
    },
    "suggest": {
        "lovata/shopaholic-plugin": "Use ShopaholicAdapter to track Lovata Shopaholic Orders",
        "lovata/ordersshopaholic-plugin": "Use ShopaholicAdapter to track Lovata Orders Shopaholic Orders"
    },
    "require-dev": {
        "larastan/larastan": "^3.0",
        "laravel/pint": "^1.26",
        "lovata/buddies-plugin": "^1.10",
        "lovata/ordersshopaholic-plugin": "^1.33",
        "lovata/shopaholic-plugin": "^1.32",
        "mockery/mockery": "^1.6",
        "pestphp/pest": "^4.1",
        "pestphp/pest-plugin-drift": "^4.0",
        "phpmd/phpmd": "^2.15",
        "phpunit/phpunit": "^12",
        "rector/rector": "^2.0",
        "shipmonk/composer-dependency-analyser": "^1.8",
        "spaze/phpstan-disallowed-calls": "^4.0"
    },
    "autoload": {
        "psr-4": {
            "Logingrupa\\Metapixel\\": ""
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Logingrupa\\Metapixel\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "qa": ["@pint-test", "@analyse", "@phpmd", "@test-cov"],
        "pint-test": "pint --test",
        "pint": "pint",
        "analyse": "phpstan analyse",
        "phpmd": "phpmd Plugin.php text phpmd.xml",
        "test": "pest",
        "test-cov": "pest --coverage --min=90",
        "rector": "rector process --dry-run",
        "deps": "composer-dependency-analyser"
    },
    "extra": {
        "october": {
            "plugin": "Logingrupa.Metapixel",
            "installer-name": "metapixel"
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
