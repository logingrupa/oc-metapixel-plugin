includes:
    - vendor/larastan/larastan/extension.neon
    - vendor/spaze/phpstan-disallowed-calls/extension.neon

parameters:
    level: 10
    phpVersion: 80300

    paths:
        - Plugin.php
        - classes
        - models
        - console
        - components

    excludePaths:
        - tests (?)
        - updates (?)
        - lang (?)
        - .github (?)
        - classes/testing (?)

    tmpDir: .phpstan-cache

    reportUnmatchedIgnoredErrors: true
    treatPhpDocTypesAsCertain: true
    checkUninitializedProperties: true

    universalObjectCratesClasses:
        - Lovata\Toolbox\Classes\Item\ElementItem
        - Lovata\Toolbox\Classes\Collection\ElementCollection

    disallowedFunctionCalls:
        -
            function: 'assert()'
            message: 'use throw — assert() is a silent no-op when zend.assertions=0 (production default)'
        -
            function: '@'
            message: 'no @ suppression — handle errors explicitly'
        -
            function: 'array_find()'
            message: 'PHP 8.4-only — use array_filter + early return or foreach'
        -
            function: 'array_find_key()'
            message: 'PHP 8.4-only — use array_keys + array_filter or foreach'
        -
            function: 'array_any()'
            message: 'PHP 8.4-only — use array_filter or foreach with early return'
        -
            function: 'array_all()'
            message: 'PHP 8.4-only — use array_filter or foreach'
        -
            function: 'request()'
            message: 'metapixel: per-event attributes MUST come from the subject via adapter — request() banned in adapter/queue/event dirs'
            # D-16: classes/adapter/theme/* excluded — ThemeActionAdapter D-15 site fallback exception
            # 03-09 Gap 2: ShopaholicCartPositionAdapter.php excluded — D-15-style site fallback (Lovata Cart has no site_id col)
            disallowIn:
                - 'classes/queue/*'
                - 'classes/event/*'
                - 'classes/adapter/shopaholic/*'
                - 'classes/event/adapter/shopaholic/*'
            allowIn:
                - 'classes/adapter/shopaholic/ShopaholicCartPositionAdapter.php'

    disallowedMethodCalls:
        -
            method: 'System\Classes\SiteManager::*'
            message: 'metapixel: site_id MUST come from subject via SiteResolver::forSubject — cross-context determinism'
            # D-16: classes/adapter/theme/* excluded — ThemeActionAdapter D-15 site fallback exception
            # 03-09 Gap 2: ShopaholicCartPositionAdapter.php excluded — D-15-style site fallback (Lovata Cart has no site_id col)
            disallowIn:
                - 'classes/queue/*'
                - 'classes/event/*'
                - 'classes/adapter/shopaholic/*'
                - 'classes/event/adapter/shopaholic/*'
            allowIn:
                - 'classes/adapter/shopaholic/ShopaholicCartPositionAdapter.php'
        -
            method: 'October\Rain\Support\Facades\Site::*'
            message: 'metapixel: site_id MUST come from subject via SiteResolver::forSubject — cross-context determinism'
            # D-16: classes/adapter/theme/* excluded — ThemeActionAdapter D-15 site fallback exception
            # 03-09 Gap 2: ShopaholicCartPositionAdapter.php excluded — D-15-style site fallback (Lovata Cart has no site_id col)
            disallowIn:
                - 'classes/queue/*'
                - 'classes/event/*'
                - 'classes/adapter/shopaholic/*'
                - 'classes/event/adapter/shopaholic/*'
            allowIn:
                - 'classes/adapter/shopaholic/ShopaholicCartPositionAdapter.php'
        -
            method: 'Illuminate\Http\Request::*'
            message: 'metapixel: per-event attributes MUST come from the subject via adapter'
            # D-16: classes/adapter/theme/* excluded — ThemeActionAdapter D-15 site fallback exception
            # 03-09 Gap 2: ShopaholicCartPositionAdapter.php excluded — D-15-style site fallback (Lovata Cart has no site_id col)
            disallowIn:
                - 'classes/queue/*'
                - 'classes/event/*'
                - 'classes/adapter/shopaholic/*'
                - 'classes/event/adapter/shopaholic/*'
            allowIn:
                - 'classes/adapter/shopaholic/ShopaholicCartPositionAdapter.php'
    disallowedStaticCalls:
        -
            # D-02 / MULT-02 lock — direct Settings::get('pixel_id'|'capi_access_token')
            # is banned outside Settings::lookupForSite (which lives in models/Settings.php)
            # and outside PluginGuard (which legitimately reads pixel_id at boot to gate
            # the plugin without leaking it through Multisite propagation).
            # Callers needing CAPI credentials MUST route through
            # Settings::lookupForSite($iSiteId) so per-site Multisite routing + the
            # silent default-row fallback (D-01) are honored.
            #
            # Rule semantics (Spaze\PHPStan\Rules\Disallowed\Allowed\Allowed::isAllowed):
            # `allowIn` short-circuits to allowed for the two whitelisted files.
            # Outside those paths, `allowExceptParamsAnywhere` only fires the disallow
            # when the first arg matches 'pixel_id' or 'capi_access_token'; calls with
            # any other key (test_event_code, default_currency_code, paid_status_code,
            # etc.) remain allowed.
            method: 'Logingrupa\Metapixel\Models\Settings::get()'
            message: 'Direct Settings::get(''pixel_id''|''capi_access_token'') is banned per D-02 — route credentials through Settings::lookupForSite($iSiteId).'
            allowIn:
                - '*/models/Settings.php'
                - '*/classes/helper/PluginGuard.php'
            allowExceptParamsAnywhere:
                -
                    position: 1
                    name: 'key'
                    value: 'pixel_id'
                -
                    position: 1
                    name: 'key'
                    value: 'capi_access_token'

    disallowedAttributes:
        -
            attribute: 'Deprecated'
            message: 'PHP 8.4-only attribute — use @deprecated docblock instead'
